# LLM Provider for Ask VoxAtlas ("openai", "anthropic", or "llama")
# Auto-detects if not set — uses whichever API key is present
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Meta Llama
LLAMA_API_KEY=your_llama_api_key_here
LLAMA_MODEL=Llama-4-Maverick-17B-128E-Instruct

# HuggingFace
HF_TOKEN=your_huggingface_token_here

# ASR Config
DEFAULT_ASR_MODEL=omniASR_CTC_1B_v2
ASR_DEVICE=cuda

# App
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000
FRONTEND_PORT=5173
SQLITE_PATH=./data/voxatlas.db
CORS_ORIGINS=http://localhost:5173
